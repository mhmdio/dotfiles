// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "bottom_dock_layout": "contained",
  "debugger": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "cli_default_open_behavior": "new_window",
  "agent_buffer_font_size": 16.0,
  "agent_ui_font_size": 16.0,
  "agent": {
    "dock": "right",
    "play_sound_when_agent_done": "when_hidden",
    "sidebar_side": "right",
    "model_parameters": []
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "claude-acp": {
      "favorite_config_option_values": {
        "effort": [
          "xhigh"
        ],
        "model": [
          "default"
        ],
        "mode": [
          "bypassPermissions"
        ]
      },
      "type": "registry",
    },
  },
  "git_panel": {
    "dock": "left",
    "tree_view": false,
  },
  "text_rendering_mode": "platform_default",
  "vim_mode": true,
  "project_panel": {
    "sort_mode": "directories_first",
    "hide_hidden": false,
    "hide_root": false,
    "entry_spacing": "standard",
    "default_width": 250.0,
    "dock": "left",
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": true,
    },
    "copy_on_select": true,
    "dock": "right",
    "font_weight": 400.0,
    "scrollbar": {
      "show": "always",
    },
    "alternate_scroll": "on",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_family": "Maple Mono NF",
  "ui_font_weight": 400.0,
  "buffer_font_weight": 400.0,
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "buffer_font_family": "Maple Mono NF",
  "ui_font_size": 18.0,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
}
